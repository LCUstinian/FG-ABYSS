src-tauri/icons/*.ico
src-tauri/icons/*.icns
src-tauri/gen
src-tauri/tauri.*.json

# Rust
src-tauri/target/
**/target/
**/*.rs.bk
**/Cargo.lock
**/*.pdb

# Node.js
.npm
.eslintcache
.nyc_output
coverage
.jest
test-results

# OS
Thumbs.db
.DS_Store
.AppleDouble
.LSOverride
._*

