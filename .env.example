# FG-ABYSS 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# 应用配置
FG_APP_ENV=development
FG_APP_VERSION=1.0.0
FG_APP_DEBUG=true

# 服务器配置
FG_SERVER_PORT=9245
FG_SERVER_HOST=localhost

# 数据库配置
FG_DB_DRIVER=sqlite
FG_DB_PATH=data/app.db

# 日志配置
FG_LOG_LEVEL=debug
FG_LOG_FORMAT=console
FG_LOG_OUTPUT=stdout

# Wails 配置
FG_WAILS_PORT=9245
FG_WAILS_HOT_RELOAD=true
