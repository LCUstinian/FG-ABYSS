{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "fg-abyss",
  "version": "0.1.0",
  "identifier": "com.fg-abyss.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FG-ABYSS",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 768,
        "decorations": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
